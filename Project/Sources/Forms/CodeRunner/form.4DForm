					"action": "cancel",
					"class": "Texts12N",
					"textAlign": "center",
					"focusable": false,
					"text": "Close",
					"style": "flat",
					"events": [
						"onClick"
					]
				},
				"Rect_Status": {
					"type": "rectangle",
					"top": 221,
					"left": 445,
					"width": 240,
					"height": 82,
					"sizingX": "move",
					"fill": "automatic",
					"stroke": "automatic",
					"strokeWidth": 1,
					"borderRadius": 5
				},
				"Label_Status": {
					"type": "text",
					"top": 225,
					"left": 455,
					"width": 220,
					"height": 16,
					"sizingX": "move",
					"stroke": "#696969",
					"class": "Texts11N",
					"fontWeight": "bold",
					"text": "Status:"
				},
				"_STATUS_": {
					"type": "input",
					"top": 243,
					"left": 455,
					"width": 220,
					"height": 56,
					"sizingX": "move",
					"dataSource": "Form:C1466.statusText",
					"class": "Texts11N",
					"fill": "transparent",
					"borderStyle": "none",
					"multiline": "yes",
