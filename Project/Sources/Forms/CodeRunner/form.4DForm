					"class": "Texts12N",
					"textAlign": "center",
					"focusable": false,
					"text": "Clear",
					"style": "flat",
					"method": "ObjectMethods/_BTN_CLEAR_.4dm",
					"events": [
						"onClick"
					]
				},
				"_BTN_CLOSE_": {
