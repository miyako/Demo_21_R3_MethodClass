{
	"destination": "detailScreen",
	"windowSizingX": "variable",
	"windowSizingY": "variable",
	"windowMinWidth": 700,
	"windowMinHeight": 520,
	"windowTitle": "Code Runner - 4D.Method",
	"rightMargin": 15,
	"bottomMargin": 15,
	"markerHeader": 15,
	"markerBody": 520,
	"markerBreak": 540,
	"markerFooter": 560,
	"formClass": "FC_CodeRunner",
	"method": "method.4dm",
	"css": [
		"CodeRunner.css"
	],
	"events": [
		"onLoad",
		"onUnload"
	],
	"pages": [
		null,
		{
			"objects": {
				"Label_Code": {
					"type": "text",
					"top": 15,
					"left": 15,
					"width": 200,
					"height": 16,
					"stroke": "#696969",
					"class": "Texts13N",
					"fontWeight": "bold",
					"text": "Source code"
				},
				"Rect_Code": {
					"type": "rectangle",
					"top": 37,
					"left": 15,
					"width": 420,
					"height": 266,
					"sizingX": "grow",
					"sizingY": "grow",
					"fill": "automatic",
					"stroke": "automatic",
					"strokeWidth": 1,
					"borderRadius": 5
				},
				"_CODE_INPUT_": {
					"type": "input",
					"top": 41,
					"left": 20,
					"width": 410,
					"height": 258,
					"sizingX": "grow",
					"sizingY": "grow",
					"dataSource": "Form:C1466.sourceCode",
					"class": "Texts13N",
					"fontFamily": "Menlo",
					"fontSize": 12,
					"fill": "transparent",
					"borderStyle": "none",
					"multiline": "yes",
					"wordwrap": "automatic",
					"contextMenu": "automatic",
					"placeholder": "Enter your 4D code here...",
					"dragging": "none",
					"dropping": "none",
					"events": [
						"onDataChange"
					]
				},
				"_BTN_OPEN_FILE_": {
					"type": "button",
					"top": 37,
					"left": 445,
					"width": 115,
					"height": 36,
					"sizingX": "move",
					"tooltip": "Open a code file",
					"class": "Texts12N",
					"textAlign": "center",
					"focusable": false,
					"text": "Open...",
					"style": "flat",
					"method": "ObjectMethods/_BTN_OPEN_FILE_.4dm",
					"events": [
						"onClick"
					]
				},
				"_BTN_SAVE_FILE_": {
					"type": "button",
					"top": 37,
					"left": 570,
					"width": 115,
					"height": 36,
					"sizingX": "move",
					"tooltip": "Save code to file",
					"class": "Texts12N",
					"textAlign": "center",
					"focusable": false,
					"text": "Save...",
					"style": "flat",
					"method": "ObjectMethods/_BTN_SAVE_FILE_.4dm",
					"events": [
						"onClick"
					]
				},
				"_BTN_CHECK_": {
					"type": "button",
					"top": 83,
					"left": 445,
					"width": 240,
					"height": 36,
					"sizingX": "move",
					"tooltip": "Check syntax of the code",
					"class": "Texts12N",
					"textAlign": "center",
					"focusable": false,
					"text": "Check Syntax",
					"style": "flat",
					"method": "ObjectMethods/_BTN_CHECK_.4dm",
					"events": [
						"onClick"
					]
				},
				"_BTN_EXECUTE_": {
					"type": "button",
					"top": 129,
					"left": 445,
					"width": 240,
					"height": 36,
					"sizingX": "move",
					"tooltip": "Execute the code",
					"class": "Texts12N",
					"textAlign": "center",
					"focusable": false,
					"text": "Execute",
					"style": "flat",
					"method": "ObjectMethods/_BTN_EXECUTE_.4dm",
					"events": [
						"onClick"
					]
				},
				"_BTN_CLEAR_": {
					"type": "button",
					"top": 175,
					"left": 445,
					"width": 115,
					"height": 36,
					"sizingX": "move",
