					"sizingY": "move",
					"dataSource": "Form:C1466.resultOutput",
					"class": "Texts13N",
					"fontFamily": "Menlo",
					"fontSize": 12,
					"fill": "transparent",
					"borderStyle": "none",
					"multiline": "yes",
					"enterable": false,
